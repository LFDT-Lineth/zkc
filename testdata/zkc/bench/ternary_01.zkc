pub input data(address:u1) -> (data:u64)
pub output casted(address:u1) -> (casted:u32)

fn main() {
    // the first branch ends up being not needed at runtime (as data[0] = 0xFF_FFFFFFFF), however it is evaluated anyway, leading to cast overflow
    casted[0] = data[0] <= 0xFFFFFFFF ? (data[0] as u32) : ((data[0] & 0xFFFFFFFF) as u32)
    // the behaviour of the above is different from:
    // if data[0] <= 0xFFFFFFFF {
    //     casted[0] = data[0] as u32
    // } else {
    //    casted[0] = (data[0] & 0xFFFFFFFF) as u32
    // }
    return
}