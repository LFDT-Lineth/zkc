include "../../impl/u32/poseidon.zkc"
include "../../impl/u32/state.zkc"
include "../../utils/memory.zkc"

// ===================================================================
// write_8 test
// ===================================================================

fn main<ram, u32_state>() {
    for i:u8 = 0; i<16; i = i + 1 {
        write_8((i * 4) as Address, i as u8)
    }
    var one:u8 = ram[4]
    if one != 1 {
        fail
    }
}
