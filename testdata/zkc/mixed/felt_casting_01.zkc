// felt casting test
// ===================================================================

fn main() {
    var neg_one:𝔽 = 0x7f000000 // ok
    var one:𝔽 = 0x1 // ok
    var zero:𝔽 = 0x0 // ok

    if (neg_one * neg_one) != one {
        fail
    }

    if (neg_one + one) != zero {
        fail
    }
}
