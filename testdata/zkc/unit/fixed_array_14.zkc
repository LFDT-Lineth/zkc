pub input data(address:u8) -> (byte:u8)
pub output result(address:u8) -> (byte:u8)

fn main() {
    var items:[u8;3]
    var items2:[u8;2]
    items, items2 = fn_two_arrays()
    result[0] = items[0] + items2[0]
    result[1] = items[1] + items2[1]
    result[2] = items[2]
    return
}

fn fn_two_arrays() -> (i:[u8;3], i2:[u8;2]) {
    i[0] = data[0]
    i[1] = data[1]
    i[2] = data[2]
    i2[0] = data[3]
    i2[1] = data[4]
}