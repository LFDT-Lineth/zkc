pub input data(address:u1) -> (data:u15)
pub output casted(address:u1) -> (casted:u8)

fn main() {
    // the not followed branch would have issue at runtime if executed
    if data[0] <= 0xFF {
        casted[0] = data[0] as u8
    } else {
        casted[0] = (data[0] & 0xFF) as u8
    }
    return
}
