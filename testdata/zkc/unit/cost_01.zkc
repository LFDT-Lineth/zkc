input data(addr:u2) -> (b:u8)

fn main() {
    var xs:[u8;2]

    #[cost:load_first]
    xs[0] = data[0]

    #[cost:load_second]
    xs[1] = data[1]

    var ys:[u8;2]

    #[cost:array_copy]
    ys = xs

    // Static cost counts WIR micro-instructions generated for this if/else.
    // Dynamic cost counts only the WIR micro-instructions on the executed branch.
    #[cost:branch]
    if ys[0] == data[0] {
        #[cost:leaf]
        ys[1] = ys[1] + 1
    } else {
        fail
    }

    // Static cost counts WIR micro-instructions generated for one lowered while.
    // Dynamic cost counts the WIR micro-instructions executed across all loop iterations.
    #[cost:loop]
    while ys[1]<data[2] {
        ys[1] = ys[1] + 1
    }

    if ys[1] != data[2] {
        fail
    }
}
